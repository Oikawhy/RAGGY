OPENAI_API_KEY=
DATABASE_URL=postgresql://consultant:consultant_dev_pw@localhost:5433/ai_consultant
REDIS_URL=redis://localhost:6379/0
LLM_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=BAAI/bge-m3
MAX_CONTEXT_TOKENS=3000
NEIGHBOR_WINDOW=1
MAX_CHUNKS=8
VECTOR_TOP_K=20
LEXICAL_TOP_K=20
RRF_K=60
TRACE_DIR=traces
TRACE_QUEUE_SIZE=1000
TRACE_ENQUEUE_TIMEOUT_MS=50
CACHE_TTL_SECONDS=3600
PROMPT_VERSION=p1
RETRIEVAL_CONFIG_HASH=default
EMBEDDING_BACKEND=fake
EMBEDDING_SERVICE_URL=
EMBEDDING_TIMEOUT_SECONDS=10
EMBEDDING_CIRCUIT_BREAKER_THRESHOLD=5
EMBEDDING_CIRCUIT_BREAKER_COOLDOWN=60
RERANKER_ENABLED=true
RERANKER_BACKEND=lexical_overlap
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_CONCURRENCY=10
EMBEDDING_MAX_CONCURRENCY=5
REDIS_CONTROL_PLANE_FAILURE_MODE=fail_open
TRACE_RETENTION_DAYS=30
